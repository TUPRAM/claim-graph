OPENAI_API_KEY=
OPENAI_DEFAULT_MODEL=gpt-5.4
OPENAI_REASONING_MODEL=
CLAIMGRAPH_OPENAI_TIMEOUT_MS=60000

CLAIMGRAPH_MODE=demo
CLAIMGRAPH_OPEN_MODEL_BACKEND=ollama
CLAIMGRAPH_OPEN_MODEL_NAME=qwen3:8b
OLLAMA_BASE_URL=http://127.0.0.1:11434
OPEN_MODEL_BASE_URL=
OPEN_MODEL_API_KEY=
# Set to 1 only when the provider's OpenAI-compatible routes are already rooted
# directly at OPEN_MODEL_BASE_URL instead of under /v1.
CLAIMGRAPH_OPEN_MODEL_EXACT_BASE_URL=0
CLAIMGRAPH_OPEN_MODEL_TIMEOUT_MS=300000
CLAIMGRAPH_RUN_STALE_AFTER_MS=420000
CLAIMGRAPH_RUN_HEARTBEAT_MS=15000

CLAIMGRAPH_STORAGE_DRIVER=local
DATABASE_URL=
NEON_PROJECT_ID=
BLOB_READ_WRITE_TOKEN=
CLAIMGRAPH_DURABLE_RUNNER=

# Canonical browser origin. Required in production for mutation-origin checks.
CLAIMGRAPH_PUBLIC_ORIGIN=https://claimgraph.example

# Isolated staging only. Rehearsal actions remain unavailable unless the role
# is exactly "staging", the explicit flag is 1, and CLAIMGRAPH_PUBLIC_ORIGIN
# differs from both this repository's production origin and the value below.
# The protected developer session is still required by the control route.
CLAIMGRAPH_DEPLOYMENT_ROLE=
CLAIMGRAPH_PRODUCTION_ORIGIN=https://claim-graph.vercel.app
CLAIMGRAPH_STAGING_REHEARSAL_ENABLED=0
# The storage driver must be hosted. DATABASE_URL must use postgres/postgresql
# and its hostname must exactly match this staging-only value.
CLAIMGRAPH_STAGING_REHEARSAL_EXPECTED_DATABASE_HOSTNAME=
# Use a staging-only value containing at least 32 random bytes. The runtime
# performs only a SELECT against claimgraph_staging_rehearsal_bindings; provision
# the staging-rehearsal row separately with the SHA-256 hash of this raw value.
# Never copy the raw secret or marker row from staging into production.
CLAIMGRAPH_STAGING_REHEARSAL_BINDING_SECRET=
# Both expected resource identities are mandatory when the flag is enabled.
# The Neon value must equal NEON_PROJECT_ID. The Blob value may include the
# Vercel API's store_ prefix; it is compared with the store encoded in the
# BLOB_READ_WRITE_TOKEN without logging the token or either identity.
CLAIMGRAPH_STAGING_REHEARSAL_EXPECTED_NEON_PROJECT_ID=
CLAIMGRAPH_STAGING_REHEARSAL_EXPECTED_BLOB_STORE_ID=

# Public-beta control secrets must contain at least 32 random bytes. Never
# commit real values. CRON_SECRET authenticates /api/internal/cleanup and the
# detailed /api/internal/health/production operator endpoint.
CLAIMGRAPH_ABUSE_HASH_SECRET=
CRON_SECRET=

# Set only behind a trusted reverse proxy that overwrites forwarding headers.
# Vercel is trusted automatically when VERCEL=1.
CLAIMGRAPH_TRUST_PROXY=0

# Bounded anonymous admission and cost defaults.
CLAIMGRAPH_CREATE_LIMIT_PER_IP=6
CLAIMGRAPH_CREATE_WINDOW_MINUTES=60
CLAIMGRAPH_CREATE_GLOBAL_LIMIT=30
CLAIMGRAPH_ANALYSIS_LIMIT_PER_WORKSPACE=5
CLAIMGRAPH_ANALYSIS_WINDOW_MINUTES=1440
CLAIMGRAPH_EXPORT_LIMIT_PER_WORKSPACE=20
CLAIMGRAPH_EXPORT_WINDOW_MINUTES=60
CLAIMGRAPH_EXPORT_GLOBAL_LIMIT=60
CLAIMGRAPH_EXPORT_MAX_MIB=8
CLAIMGRAPH_FILE_MUTATION_LIMIT_PER_WORKSPACE=30
CLAIMGRAPH_FILE_MUTATION_GLOBAL_LIMIT=60
CLAIMGRAPH_UPLOAD_BYTE_LIMIT_MIB=50
CLAIMGRAPH_PAID_ANALYSIS_DAILY_LIMIT=20
CLAIMGRAPH_PROVIDER_CONCURRENCY=2
CLAIMGRAPH_PROVIDER_LEASE_MINUTES=15
CLAIMGRAPH_PUBLIC_ANALYSIS_ENABLED=true
CLAIMGRAPH_IDEMPOTENCY_TTL_HOURS=24
CLAIMGRAPH_WORKSPACE_CAPABILITY_TTL_SECONDS=2592000

# Retention and retryable cleanup.
CLAIMGRAPH_ABANDONED_WORKSPACE_TTL_DAYS=14
CLAIMGRAPH_UPLOAD_TTL_DAYS=30
CLAIMGRAPH_EXPORT_TTL_HOURS=24
CLAIMGRAPH_QA_WORKSPACE_TTL_HOURS=24
CLAIMGRAPH_CLEANUP_BATCH_SIZE=25
CLAIMGRAPH_CLEANUP_DRAIN_LIMIT=500
CLAIMGRAPH_CLEANUP_MAX_SECONDS=45
CLAIMGRAPH_CLEANUP_MAX_ATTEMPTS=10

# Protected operator-login throttles.
CLAIMGRAPH_DEV_LOGIN_LIMIT_PER_IP=5
CLAIMGRAPH_DEV_LOGIN_GLOBAL_LIMIT=30

SEARXNG_BASE_URL=
PLAYWRIGHT_RETRIEVAL_ENABLED=false

# Developer lane password gate. Generate DEV_MODE_PASSWORD_HASH with
# createDevPasswordHash from lib/server/dev-auth.ts or a one-off Node script.
DEV_MODE_PASSWORD_HASH=
DEV_MODE_SESSION_SECRET=
