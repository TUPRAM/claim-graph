{
  "name": "claimgraph",
  "private": true,
  "version": "0.1.0",
  "description": "A graph-first workspace for mapping claims, counterclaims, evidence, provenance, and unresolved gaps.",
  "engines": {
    "node": "24.x",
    "npm": "11.x"
  },
  "scripts": {
    "dev": "next dev --webpack",
    "build": "next build",
    "postbuild": "node scripts/check-readiness-nft-trace.mjs",
    "start": "next start",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "audit:security": "node scripts/audit-production-dependencies.mjs",
    "runtime:check": "node scripts/check-runtime-readiness.mjs",
    "qa:workspace": "node scripts/browser-workspace-qa.mjs",
    "qa:workspace:screenshots": "node scripts/browser-workspace-qa.mjs --screenshots",
    "qa:workspace:review": "node scripts/browser-workspace-qa.mjs --review"
  },
  "dependencies": {
    "@neondatabase/serverless": "^1.1.0",
    "@vercel/blob": "^2.4.0",
    "@xyflow/react": "12.10.2",
    "better-sqlite3": "12.11.1",
    "dagre": "0.8.5",
    "geist": "^1.7.2",
    "html-to-image": "1.11.13",
    "next": "16.2.10",
    "openai": "6.33.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "workflow": "4.6.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@electric-sql/pglite": "^0.5.4",
    "@testing-library/react": "16.3.2",
    "@types/better-sqlite3": "7.6.13",
    "@types/dagre": "0.7.54",
    "@types/node": "25.9.5",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "jsdom": "27.4.0",
    "typescript": "6.0.3",
    "vitest": "4.1.10"
  },
  "overrides": {
    "next": {
      "postcss": "8.5.10"
    }
  }
}
